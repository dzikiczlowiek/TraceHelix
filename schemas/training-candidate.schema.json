{
  "$comment": "TraceHelix contract_validator is REQUIRED for relational identity/count/provenance invariants.",
  "$defs": {
    "ContextEvent": {
      "additionalProperties": false,
      "properties": {
        "event_id": {
          "minLength": 1,
          "title": "Event Id",
          "type": "string"
        },
        "event_kind": {
          "minLength": 1,
          "title": "Event Kind",
          "type": "string"
        },
        "event_text": {
          "title": "Event Text",
          "type": "string"
        },
        "tool_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Name"
        }
      },
      "required": [
        "event_id",
        "event_text",
        "event_kind"
      ],
      "title": "ContextEvent",
      "type": "object"
    },
    "SourceCategory": {
      "enum": [
        "fake",
        "fixture",
        "live"
      ],
      "title": "SourceCategory",
      "type": "string"
    }
  },
  "$id": "https://tracehelix.dev/schemas/training-candidate.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "adapter": {
      "minLength": 1,
      "title": "Adapter",
      "type": "string"
    },
    "adapter_version": {
      "minLength": 1,
      "title": "Adapter Version",
      "type": "string"
    },
    "context_after": {
      "items": {
        "$ref": "#/$defs/ContextEvent"
      },
      "title": "Context After",
      "type": "array"
    },
    "context_before": {
      "items": {
        "$ref": "#/$defs/ContextEvent"
      },
      "title": "Context Before",
      "type": "array"
    },
    "event_id": {
      "minLength": 1,
      "title": "Event Id",
      "type": "string"
    },
    "event_kind": {
      "minLength": 1,
      "title": "Event Kind",
      "type": "string"
    },
    "event_text": {
      "title": "Event Text",
      "type": "string"
    },
    "example_id": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Example Id",
      "type": "string"
    },
    "license_or_consent": {
      "minLength": 1,
      "title": "License Or Consent",
      "type": "string"
    },
    "lineage_id": {
      "minLength": 1,
      "title": "Lineage Id",
      "type": "string"
    },
    "redaction_version": {
      "minLength": 1,
      "title": "Redaction Version",
      "type": "string"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_category": {
      "$ref": "#/$defs/SourceCategory"
    },
    "source_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Source Hash",
      "type": "string"
    },
    "task_group_id": {
      "minLength": 1,
      "title": "Task Group Id",
      "type": "string"
    },
    "tool_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tool Name"
    }
  },
  "required": [
    "schema_version",
    "example_id",
    "run_id",
    "event_id",
    "task_group_id",
    "lineage_id",
    "context_before",
    "event_text",
    "context_after",
    "event_kind",
    "source_category",
    "source_hash",
    "adapter",
    "adapter_version",
    "redaction_version",
    "license_or_consent"
  ],
  "title": "TrainingCandidate",
  "type": "object",
  "x-tracehelix-invariants": true
}
