{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://tracehelix.local/schemas/trace-event.schema.json","title":"TraceHelix canonical trace event","type":"object","additionalProperties":false,
  "required":["id","runId","sequence","timestamp","kind","actor","payload","source","artifacts","contentSha256"],
  "properties":{"id":{"type":"string","format":"uuid"},"runId":{"type":"string","format":"uuid"},"sequence":{"type":"integer","minimum":0},"timestamp":{"type":"string","format":"date-time"},"kind":{"enum":["Message","Reasoning","ToolCall","ToolResult","FileChange","Artifact","Status","Error","Unknown"]},"actor":{"type":"string","minLength":1},"summary":{"type":["string","null"]},"payload":{},"source":{"$ref":"#/$defs/source"},"artifacts":{"type":"array","items":{"$ref":"#/$defs/artifact"}},"contentSha256":{"type":"string","pattern":"^[a-f0-9]{64}$"}},
  "$defs":{"source":{"type":"object","additionalProperties":false,"required":["adapter","inputSha256","relativePath"],"properties":{"adapter":{"type":"string","minLength":1},"inputSha256":{"type":"string","pattern":"^[a-f0-9]{64}$"},"relativePath":{"type":"string","minLength":1},"byteOffset":{"type":["integer","null"],"minimum":0},"line":{"type":["integer","null"],"minimum":1},"jsonPointer":{"type":["string","null"]}}},"artifact":{"type":"object","required":["name"],"properties":{"name":{"type":"string"},"path":{"type":["string","null"]},"sha256":{"type":["string","null"]}}}}
}
